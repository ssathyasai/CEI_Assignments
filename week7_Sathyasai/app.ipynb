    "## 13. Experiments: Chunk Size Optimization\n",
    "\n",
    "Testing different chunk sizes to find optimal configuration."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def experiment_chunk_sizes(documents, chunk_sizes=[500, 1000, 1500], overlap=100):\n",
    "    \"\"\"\n",
    "    Experiment with different chunk sizes.\n",
    "    \"\"\"\n",
    "    print(\"\\n\" + \"=\"*80)\n",
    "    print(\"🧪 EXPERIMENT 1: CHUNK SIZE OPTIMIZATION\")\n",
    "    print(\"=\"*80)\n",
    "    \n",
    "    results = []\n",
    "    \n",
    "    for chunk_size in chunk_sizes:\n",
    "        print(f\"\\n📏 Testing chunk size: {chunk_size} characters\")\n",
    "        print(\"-\" * 80)\n",
    "        \n",
    "        # Create splitter\n",
    "        splitter = RecursiveCharacterTextSplitter(\n",
    "            chunk_size=chunk_size,\n",
    "            chunk_overlap=overlap,\n",
    "            length_function=len\n",
    "        )\n",
    "        \n",
    "        # Split documents\n",
    "        start_time = time.time()\n",
    "        chunks = splitter.split_documents(documents)\n",
    "        split_time = time.time() - start_time\n",
    "        \n",
    "        # Calculate statistics\n",
    "        chunk_lengths = [len(chunk.page_content) for chunk in chunks]\n",
    "        \n",
    "        result = {\n",
    "            'chunk_size': chunk_size,\n",
    "            'total_chunks': len(chunks),\n",
    "            'avg_length': np.mean(chunk_lengths),\n",
    "            'std_length': np.std(chunk_lengths),\n",
    "            'split_time': split_time\n",
    "        }\n",
    "        results.append(result)\n",
    "        \n",
    "        print(f\"Total Chunks Created:     {result['total_chunks']}\")\n",
        "        print(f\"Average Chunk Length:     {result['avg_length']:.0f} chars\")\n",
    "        print(f\"Std Dev:                  {result['std_length']:.0f} chars\")\n",
    "        print(f\"Processing Time:          {result['split_time']:.3f} seconds\")\n",
    "    \n",
    "    # Create summary table\n",
    "    print(\"\\n📊 SUMMARY TABLE:\")\n",
    "    df = pd.DataFrame(results)\n",
    "    print(df.to_string(index=False))\n",
    "    \n",
    "    print(\"\\n💡 OBSERVATIONS:\")\n",
    "    print(\"- Smaller chunks create more chunks but may lose context\")\n",
    "    print(\"- Larger chunks preserve context but may include irrelevant information\")\n",
    "    print(\"- Optimal chunk size depends on document structure and query type\")\n",
    "    \n",
    "    return results\n",
    "\n",
    "# Run experiment\n",
    "if documents:\n",
    "    chunk_size_results = experiment_chunk_sizes(documents)"
