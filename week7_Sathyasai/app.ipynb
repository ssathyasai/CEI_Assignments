  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Document Ingestion Module\n",
    "\n",
    "Loading PDF and text documents from the data directory."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class DocumentIngestion:\n",
    "    \"\"\"\n",
    "    Handles loading and preprocessing of documents from various sources.\n",
    "    Supports: PDF files, TXT files, and directories.\n",
    "    \"\"\"\n",
    "    \n",
    "    def __init__(self, data_dir: str):\n",
    "        self.data_dir = Path(data_dir)\n",
    "        self.documents = []\n",
    "    \n",
    "    def load_pdf(self, pdf_path: str) -> List[Any]:\n",
    "        \"\"\"Load a single PDF file.\"\"\"\n",
    "        try:\n",
    "            loader = PyPDFLoader(pdf_path)\n",
    "            docs = loader.load()\n",
    "            print(f\"✅ Loaded PDF: {pdf_path} ({len(docs)} pages)\")\n",
    "            return docs\n",
    "        except Exception as e:\n",
    "            print(f\"❌ Error loading {pdf_path}: {str(e)}\")\n",
    "            return []\n",
    "    \n",
    "    def load_text(self, txt_path: str) -> List[Any]:\n",
    "        \"\"\"Load a single text file.\"\"\"\n",
    "        try:\n",
    "            loader = TextLoader(txt_path)\n",
    "            docs = loader.load()\n",
    "            print(f\"✅ Loaded TXT: {txt_path}\")\n",
    "            return docs\n",
    "        except Exception as e:\n",
    "            print(f\"❌ Error loading {txt_path}: {str(e)}\")\n",
    "            return []\n",
    "    \n",
    "    def load_all_documents(self) -> List[Any]:\n",
    "        \"\"\"Load all supported documents from data directory.\"\"\"\n",
    "        if not self.data_dir.exists():\n",
    "            print(f\"❌ Data directory not found: {self.data_dir}\")\n",
    "            return []\n",
    "        \n",
    "        print(f\"\\n📂 Loading documents from: {self.data_dir}\")\n",
    "        print(\"=\" * 60)\n",
    "        \n",
    "        # Load PDF files\n",
    "        pdf_files = list(self.data_dir.glob('*.pdf'))\n",
    "        for pdf_file in pdf_files:\n",
    "            docs = self.load_pdf(str(pdf_file))\n",
    "            self.documents.extend(docs)\n",
    "        \n",
    "        # Load TXT files\n",
    "        txt_files = list(self.data_dir.glob('*.txt'))\n",
    "        for txt_file in txt_files:\n",
    "            docs = self.load_text(str(txt_file))\n",
    "            self.documents.extend(docs)\n",
        "\n",
    "        print(\"=\" * 60)\n",
    "        print(f\"📊 Total documents loaded: {len(self.documents)}\")\n",
    "        \n",
    "        if len(self.documents) == 0:\n",
    "            print(\"\\n⚠️  No documents found! Please add PDF or TXT files to the 'data' folder.\")\n",
    "        \n",
    "        return self.documents\n",
    "\n",
    "# Initialize and load documents\n",
    "doc_loader = DocumentIngestion(CONFIG['DATA_DIR'])\n",
    "documents = doc_loader.load_all_documents()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Text Chunking Module\n",
    "\n",
    "Splitting documents into smaller, manageable chunks with overlap."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class TextChunker:\n",
    "    \"\"\"\n",
    "    Splits large documents into smaller chunks for better retrieval accuracy.\n",
    "    Uses RecursiveCharacterTextSplitter for intelligent splitting.\n",
    "    \"\"\"\n",
    "    \n",
    "    def __init__(self, chunk_size: int, chunk_overlap: int):\n",
    "        self.chunk_size = chunk_size\n",
    "        self.chunk_overlap = chunk_overlap\n",
    "        self.text_splitter = RecursiveCharacterTextSplitter(\n",
    "            chunk_size=chunk_size,\n",
    "            chunk_overlap=chunk_overlap,\n",
    "            length_function=len,\n",
    "            separators=[\"\\n\\n\", \"\\n\", \" \", \"\"]\n",
    "        )\n",
    "    \n",
    "    def split_documents(self, documents: List[Any]) -> List[Any]:\n",
    "        \"\"\"Split documents into chunks.\"\"\"\n",
    "        if not documents:\n",
            "            print(\"⚠️  No documents to split!\")\n",
    "            return []\n",
    "        \n",
    "        print(f\"\\n✂️  Splitting documents into chunks...\")\n",
    "        print(f\"   Chunk Size: {self.chunk_size} characters\")\n",
    "        print(f\"   Chunk Overlap: {self.chunk_overlap} characters\")\n",
    "        \n",
    "        chunks = self.text_splitter.split_documents(documents)\n",
    "        \n",
    "        print(f\"✅ Created {len(chunks)} text chunks\")\n",
    "        \n",
    "        # Display sample chunk\n",
    "        if chunks:\n",
    "            print(f\"\\n📄 Sample Chunk (first 200 characters):\")\n",
    "            print(\"=\" * 60)\n",
    "            print(chunks[0].page_content[:200] + \"...\")\n",
    "            print(\"=\" * 60)\n",
    "        \n",
    "        return chunks\n",
    "\n",
    "# Create chunks\n",
    "chunker = TextChunker(\n",
    "    chunk_size=CONFIG['CHUNK_SIZE'],\n",
    "    chunk_overlap=CONFIG['CHUNK_OVERLAP']\n",
    ")\n",
    "text_chunks = chunker.split_documents(documents)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Embedding Creation and Vector Store\n",
    "\n",
    "Converting text chunks into vector embeddings and storing them in FAISS."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class VectorStoreManager:\n",
    "    \"\"\"\n",
    "    Manages embedding creation and FAISS vector store operations.\n",
    "    \"\"\"\n",
    "    \n",
    "    def __init__(self, embedding_model: str):\n",
    "        print(f\"\\n🔄 Initializing embedding model: {embedding_model}\")\n",
        "        \n",
    "        # Initialize Hugging Face Embeddings\n",
    "        self.embeddings = HuggingFaceEmbeddings(\n",
    "            model_name=embedding_model,\n",
    "            model_kwargs={'device': 'cpu'},\n",
    "            encode_kwargs={'normalize_embeddings': True}\n",
    "        )\n",
    "        \n",
    "        print(\"✅ Embedding model loaded successfully!\")\n",
    "        \n",
    "        self.vector_store = None\n",
    "    \n",
    "    def create_vector_store(self, chunks: List[Any]) -> FAISS:\n",
    "        \"\"\"Create FAISS vector store from text chunks.\"\"\"\n",
    "        if not chunks:\n",
    "            print(\"❌ No chunks provided for embedding!\")\n",
    "            return None\n",
    "        \n",
    "        print(f\"\\n🔢 Creating embeddings for {len(chunks)} chunks...\")\n",
    "        start_time = time.time()\n",
    "        \n",
    "        # Create FAISS vector store\n",
    "        self.vector_store = FAISS.from_documents(\n",
    "            documents=chunks,\n",
    "            embedding=self.embeddings\n",
    "        )\n",
    "        \n",
    "        elapsed_time = time.time() - start_time\n",
    "        print(f\"✅ Vector store created in {elapsed_time:.2f} seconds\")\n",
    "        print(f\"📊 Total vectors in store: {len(chunks)}\")\n",
    "        \n",
    "        return self.vector_store\n",
    "    \n",
    "    def save_vector_store(self, path: str = \"./vector_store\"):\n",
    "        \"\"\"Save vector store to disk.\"\"\"\n",
    "        if self.vector_store:\n",
    "            self.vector_store.save_local(path)\n",
    "            print(f\"💾 Vector store saved to: {path}\")\n",
    "    \n",
    "    def load_vector_store(self, path: str = \"./vector_store\"):\n",
    "        \"\"\"Load vector store from disk.\"\"\"\n",
    "        self.vector_store = FAISS.load_local(path, self.embeddings)\n",
    "        print(f\"📂 Vector store loaded from: {path}\")\n",
    "        return self.vector_store\n",
    "\n",
    "# Create vector store\n",
    "vector_manager = VectorStoreManager(CONFIG['EMBEDDING_MODEL'])\n",
    "vector_store = vector_manager.create_vector_store(text_chunks)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Retrieval System\n",
    "\n",
    "Setting up the retrieval mechanism to find relevant document chunks."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class RetrievalSystem:\n",
    "    \"\"\"\n",
    "    Handles similarity search and retrieval of relevant document chunks.\n",
    "    \"\"\"\n",
    "    \n",
    "    def __init__(self, vector_store: FAISS, top_k: int = 4):\n",
    "        self.vector_store = vector_store\n",
    "        self.top_k = top_k\n",
    "        self.retriever = vector_store.as_retriever(\n",
    "            search_kwargs={\"k\": top_k}\n",
    "        )\n",
    "    \n",
    "    def retrieve(self, query: str) -> List[Any]:\n",
    "        \"\"\"Retrieve relevant documents for a query.\"\"\"\n",
    "        print(f\"\\n🔍 Retrieving top {self.top_k} relevant chunks...\")\n",
    "        start_time = time.time()\n",
    "        \n",
    "        # Perform similarity search\n",
    "        retrieved_docs = self.retriever.get_relevant_documents(query)\n",
    "        \n",
    "        elapsed_time = time.time() - start_time\n",
    "        print(f\"✅ Retrieved {len(retrieved_docs)} chunks in {elapsed_time:.3f} seconds\")\n",
    "        \n",
    "        return retrieved_docs\n",
    "    \n",
    "    def retrieve_with_scores(self, query: str) -> List[tuple]:\n",
    "        \"\"\"Retrieve documents with similarity scores.\"\"\"\n",
    "        results = self.vector_store.similarity_search_with_score(query, k=self.top_k)\n",
    "        return results\n",
    "\n",
    "# Initialize retrieval system\n",
    "if vector_store:\n",
    "    retrieval_system = RetrievalSystem(\n",
        "        vector_store=vector_store,\n",
    "        top_k=CONFIG['RETRIEVAL_TOP_K']\n",
    "    )\n",
    "    print(\"✅ Retrieval system initialized!\")\n",
    "else:\n",
    "    print(\"❌ Vector store not available. Cannot initialize retrieval system.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Answer Generation with Google Gemini\n",
    "\n",
    "Setting up the LLM and RAG chain for answer generation."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class RAGAnswerGenerator:\n",
    "    \"\"\"\n",
    "    Generates answers using retrieved context and Google Gemini LLM.\n",
    "    \"\"\"\n",
    "    \n",
    "    def __init__(self, retriever, model_name: str, temperature: float = 0.3):\n",
    "        print(f\"\\n🤖 Initializing LLM: {model_name}\")\n",
    "        \n",
    "        # Initialize Google Gemini LLM\n",
    "        self.llm = ChatGoogleGenerativeAI(\n",
    "            model=model_name,\n",
    "            temperature=temperature,\n",
    "            max_output_tokens=CONFIG['LLM_MAX_OUTPUT_TOKENS']\n",
    "        )\n",
    "        \n",
    "        # Create custom prompt template\n",
    "        prompt_template = \"\"\"You are a helpful AI assistant that answers questions based on the provided context.\n",
    "Use only the information from the context below to answer the question. If the answer cannot be found in the context, say \"I cannot answer this based on the provided documents.\"\n",
    "\n",
    "Context:\n",
    "{context}\n",
    "\n",
    "Question: {question}\n",
    "\n",
    "Answer:\"\"\"\n",
    "        \n",
    "        self.prompt = PromptTemplate(\n",
    "            template=prompt_template,\n",
    "            input_variables=[\"context\", \"question\"]\n",
    "        )\n",
    "        \n",
    "        # Create RetrievalQA chain\n",
    "        self.qa_chain = RetrievalQA.from_chain_type(\n",
            "            llm=self.llm,\n",
    "            chain_type=\"stuff\",\n",
    "            retriever=retriever,\n",
    "            return_source_documents=True,\n",
    "            chain_type_kwargs={\"prompt\": self.prompt}\n",
    "        )\n",
    "        \n",
    "        print(\"✅ RAG Answer Generator initialized!\")\n",
    "    \n",
    "    def generate_answer(self, query: str) -> Dict[str, Any]:\n",
    "        \"\"\"Generate answer for a given query.\"\"\"\n",
    "        print(f\"\\n💭 Generating answer for: '{query}'\")\n",
    "        start_time = time.time()\n",
    "        \n",
    "        # Generate answer\n",
    "        result = self.qa_chain.invoke({\"query\": query})\n",
    "        \n",
    "        elapsed_time = time.time() - start_time\n",
    "        print(f\"✅ Answer generated in {elapsed_time:.2f} seconds\")\n",
    "        \n",
    "        return result\n",
    "\n",
    "# Initialize Answer Generator\n",
    "if vector_store:\n",
    "    answer_generator = RAGAnswerGenerator(\n",
    "        retriever=retrieval_system.retriever,\n",
    "        model_name=CONFIG['LLM_MODEL'],\n",
    "        temperature=CONFIG['LLM_TEMPERATURE']\n",
    "    )\n",
    "else:\n",
    "    print(\"❌ Cannot initialize answer generator without vector store.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 9. Complete RAG Pipeline Function\n",
    "\n",
    "A unified function to process queries end-to-end."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def ask_question(question: str, show_sources: bool = True):\n",
    "    \"\"\"\n",
    "    Complete RAG pipeline: retrieves context and generates answer.\n",
    "    \n",
    "    Args:\n",
    "        question: User's question\n",
    "        show_sources: Whether to display retrieved source chunks\n",
    "    \"\"\"\n",
    "    print(\"\\n\" + \"=\"*80)\n",
    "    print(f\"❓ QUESTION: {question}\")\n",
    "    print(\"=\"*80)\n",
    "    \n",
    "    # Generate answer\n",
    "    result = answer_generator.generate_answer(question)\n",
    "    \n",
    "    # Display retrieved sources\n",
    "    if show_sources and 'source_documents' in result:\n",
    "        print(\"\\n📚 RETRIEVED DOCUMENT CHUNKS:\")\n",
    "        print(\"=\" * 80)\n",
    "        for i, doc in enumerate(result['source_documents'], 1):\n",
    "            print(f\"\\n[Chunk {i}]\")\n",
    "            print(\"-\" * 80)\n",
    "            print(doc.page_content[:500] + \"...\" if len(doc.page_content) > 500 else doc.page_content)\n",
    "            if hasattr(doc, 'metadata') and doc.metadata:\n",
    "                print(f\"\\nMetadata: {doc.metadata}\")\n",
    "    \n",
    "    # Display answer\n",
    "    print(\"\\n\" + \"=\"*80)\n",
    "    print(\"💡 GENERATED ANSWER:\")\n",
    "    print(\"=\" * 80)\n",
    "    print(result['result'])\n",
    "    print(\"=\" * 80)\n",
    "    \n",
    "    return result\n",
    "\n",
    "print(\"✅ RAG Pipeline ready! Use ask_question('your question here') to query.\")"
   ]
  },
