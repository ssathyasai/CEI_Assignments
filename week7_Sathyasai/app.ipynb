   "source": [
    "def benchmark_system(num_queries=5):\n",
    "    \"\"\"\n",
    "    Benchmark the complete RAG system performance.\n",
    "    \"\"\"\n",
    "    print(\"\\n\" + \"=\"*80)\n",
    "    print(\"⚡ PERFORMANCE BENCHMARKING\")\n",
    "    print(\"=\"*80)\n",
    "    \n",
    "    test_queries = [\n",
    "        \"What is this document about?\",\n",
    "        \"Summarize the key points.\",\n",
    "        \"What are the main objectives?\",\n",
    "        \"Explain the methodology.\",\n",
    "        \"What are the conclusions?\"\n",
    "    ][:num_queries]\n",
    "    \n",
    "    retrieval_times = []\n",
    "    generation_times = []\n",
    "    total_times = []\n",
    "    \n",
    "    for query in test_queries:\n",
    "        # Measure retrieval time\n",
    "        start = time.time()\n",
    "        docs = retrieval_system.retrieve(query)\n",
    "        retrieval_time = time.time() - start\n",
    "        retrieval_times.append(retrieval_time)\n",
    "        \n",
    "        # Measure total time (including generation)\n",
    "        start = time.time()\n",
    "        result = answer_generator.generate_answer(query)\n",
    "        total_time = time.time() - start\n",
    "        total_times.append(total_time)\n",
    "        \n",
    "        generation_time = total_time - retrieval_time\n",
    "        generation_times.append(generation_time)\n",
    "    \n",
    "    # Display results\n",
    "    print(f\"\\n📊 Performance Metrics (n={num_queries} queries):\")\n",
    "    print(\"-\" * 80)\n",
    "    print(f\"Average Retrieval Time:       {np.mean(retrieval_times):.3f} seconds\")\n",
    "    print(f\"Average Generation Time:      {np.mean(generation_times):.3f} seconds\")\n",
    "    print(f\"Average Total Time:           {np.mean(total_times):.3f} seconds\")\n",
    "    print(f\"\\nMin Total Time:               {np.min(total_times):.3f} seconds\")\n",
    "    print(f\"Max Total Time:               {np.max(total_times):.3f} seconds\")\n",
    "    print(f\"Std Dev:                      {np.std(total_times):.3f} seconds\")\n",
    "    \n",
    "    return {\n",
    "        'retrieval_times': retrieval_times,\n",
    "        'generation_times': generation_times,\n",
    "        'total_times': total_times\n",
    "    }\n",
    "\n",
    "# Run benchmark\n",
    "if vector_store and documents:\n",
    "    benchmark_results = benchmark_system(num_queries=3)"
