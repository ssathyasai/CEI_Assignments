    "## 12. System Metrics and Performance Report\n",
    "\n",
    "Detailed metrics about the RAG system configuration and performance."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def generate_metrics_report():\n",
    "    \"\"\"\n",
    "    Generate a comprehensive metrics report for the RAG system.\n",
    "    \"\"\"\n",
    "    print(\"\\n\" + \"=\"*80)\n",
    "    print(\"📊 RAG SYSTEM METRICS REPORT\")\n",
    "    print(\"=\"*80)\n",
    "    \n",
    "    # Document Statistics\n",
    "    print(\"\\n📄 DOCUMENT STATISTICS:\")\n",
    "    print(\"-\" * 80)\n",
    "    print(f\"Total Documents Loaded:        {len(documents)}\")\n",
    "    print(f\"Total Text Chunks:             {len(text_chunks)}\")\n",
    "    \n",
    "    if text_chunks:\n",
        "        chunk_lengths = [len(chunk.page_content) for chunk in text_chunks]\n",
    "        print(f\"Average Chunk Length:          {np.mean(chunk_lengths):.0f} characters\")\n",
