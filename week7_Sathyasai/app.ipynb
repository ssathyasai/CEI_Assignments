    "    'LLM_MODEL': 'gemini-pro',\n",
    "    'LLM_TEMPERATURE': 0.3,\n",
    "    'LLM_MAX_OUTPUT_TOKENS': 1024,\n",
    "}\n",
    "\n",
    "# Display configuration\n",
    "print(\"📊 System Configuration:\")\n",
    "print(\"=\" * 50)\n",
    "for key, value in CONFIG.items():\n",
    "    print(f\"{key:25s}: {value}\")\n",
    "print(\"=\" * 50)"
   ]
