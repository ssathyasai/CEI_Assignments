    "    print(df.to_string(index=False))\n",
    "    \n",
    "    print(\"\\n💡 OBSERVATIONS:\")\n",
    "    print(\"- Higher k provides more context but may include less relevant chunks\")\n",
    "    print(\"- Lower k is faster but may miss important information\")\n",
